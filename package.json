        "dotenv": "^16.4.5",
        "node-cron": "^4.2.1",
        "telegraf": "^4.16.0"
    },
    "devDependencies": {
        "eslint": "^9.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
