{
    "name": "fabrexa-ai",
    "version": "3.2.0",
    "description": "Telegram AI Bot powered by local Ollama models",
    "main": "bot.js",
    "type": "module",
    "scripts": {
        "start": "node bot.js",
        "dev": "node --env-file=.env bot.js",
        "check": "node check-setup.js",
        "lint": "eslint bot.js \"src/**/*.js\" \"scripts/**/*.js\"",
        "memory-process": "node scripts/memory-process.js"
