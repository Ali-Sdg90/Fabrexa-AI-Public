TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OWNER_ID=123456789

# true = only OWNER_ID can use the bot, false = public bot.
BOT_PRIVATE=true

# Local Ollama server.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:12b

# Optional: use a smaller/faster model for smart memory JSON analysis.
# OLLAMA_ANALYZER_MODEL=gemma3:12b

# normal = clean logs, dev-mode = payloads and detailed Ollama metadata.
LOG_MODE=normal

# Optional generation/runtime settings.
REQUEST_TIMEOUT=120000
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.8
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=512
TELEGRAM_STREAM_EDIT_INTERVAL_MS=6000
MEMORY_PROCESSOR_CRON=0 0 * * *
MEMORY_PROCESSOR_TIMEZONE=Asia/Tehran

# Optional comma-separated personality keys or display names that may use memory.
MEMORY_ENABLED_PERSONALITIES=
